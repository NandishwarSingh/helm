# Copy this file to ".env" and fill in real values. ".env" is never committed.
# The schema in "src/env.js" validates these at boot.

# Postgres connection string. Corsair caches Gmail and Calendar entities here.
DATABASE_URL="postgresql://postgres:password@localhost:5432/helm"

# Key-encryption key for Corsair's envelope encryption of per-tenant secrets.
# Generate one with:  openssl rand -base64 32
CORSAIR_KEK=""

# Secret used to HMAC-sign the session cookie that scopes each user's tenant.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth client (Web application) for the single combined Gmail+Calendar
# consent. Register http(s)://<host>/api/oauth/callback as an authorized
# redirect URI. Same values are also registered with Corsair via `corsair setup`.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Fallback Corsair tenant for CLI/local use when no session cookie is present.
TENANT_ID="dev"

# Public site origin, used for canonical URLs, sitemap and robots.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
